<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fiskaltrust.Middleware.Demo.IssuingPage"
             Title="Issuing Operations">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Current Protocol Display -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,15">
                <Label Text="Protocol:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label x:Name="lblCurrentProtocol"
                       Text="gRPC"
                       TextColor="#2196F3"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Label Text="? Change in Settings"
                       FontSize="12"
                       TextColor="Gray"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Retry Last Operation Button -->
            <Button x:Name="btnRetryLastOperation"
                    Text="?? Retry Last Issuing Operation"
                    Clicked="OnRetryLastOperationClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    IsVisible="False"
                    Margin="0,0,0,10" />

            <!-- Issuing Section -->
            <Frame BackgroundColor="#F8F9FA" Padding="15" CornerRadius="8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="?? Document Issuing Operations"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#2196F3"
                           HorizontalOptions="Center" />

                    <!-- Document Type Selection -->
                    <StackLayout>
                        <Label Text="Document Type:" FontAttributes="Bold" />
                        <Picker x:Name="pickerDocumentType">
                            <Picker.Items>
                                <x:String>Invoice</x:String>
                                <x:String>Receipt</x:String>
                                <x:String>Credit Note</x:String>
                                <x:String>Delivery Note</x:String>
                                <x:String>Quote</x:String>
                            </Picker.Items>
                        </Picker>
                    </StackLayout>

                    <!-- Document Number Input -->
                    <StackLayout>
                        <Label Text="Document Number:" FontAttributes="Bold" />
                        <Entry x:Name="entryDocumentNumber"
                               Placeholder="Enter document number (auto-generated if empty)" />
                    </StackLayout>

                    <!-- Customer Info -->
                    <StackLayout>
                        <Label Text="Customer Name:" FontAttributes="Bold" />
                        <Entry x:Name="entryCustomerName"
                               Placeholder="Enter customer name"
                               Text="Sample Customer" />
                    </StackLayout>

                    <StackLayout>
                        <Label Text="Customer ID:" FontAttributes="Bold" />
                        <Entry x:Name="entryCustomerId"
                               Placeholder="Optional customer ID" />
                    </StackLayout>

                    <!-- Document Amount -->
                    <StackLayout>
                        <Label Text="Total Amount:" FontAttributes="Bold" />
                        <Entry x:Name="entryDocumentAmount"
                               Placeholder="Enter total amount (e.g., 100.50)"
                               Keyboard="Numeric"
                               Text="50.00" />
                    </StackLayout>

                    <!-- Currency Selection -->
                    <StackLayout>
                        <Label Text="Currency:" FontAttributes="Bold" />
                        <Picker x:Name="pickerCurrency">
                            <Picker.Items>
                                <x:String>EUR</x:String>
                                <x:String>USD</x:String>
                                <x:String>GBP</x:String>
                                <x:String>CHF</x:String>
                            </Picker.Items>
                        </Picker>
                    </StackLayout>

                    <!-- Description -->
                    <StackLayout>
                        <Label Text="Description:" FontAttributes="Bold" />
                        <Editor x:Name="editorDescription"
                                Placeholder="Enter document description"
                                Text="Sample document description"
                                HeightRequest="80" />
                    </StackLayout>

                    <!-- Issue Buttons -->
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="btnIssueDocument"
                                Text="Issue Document"
                                Clicked="OnIssueDocumentClicked"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="btnClearIssuingForm"
                                Text="Clear Form"
                                Clicked="OnClearIssuingFormClicked"
                                BackgroundColor="#9E9E9E"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Issuing Result Section -->
            <StackLayout>
                <Label Text="Issuing Result:" FontAttributes="Bold" />
                <Frame BackgroundColor="#FAFAFA" Padding="10" CornerRadius="5">
                    <Label x:Name="lblIssuingResult"
                           Text="No issuing operations performed yet."
                           FontFamily="Courier"
                           FontSize="12" />
                </Frame>
            </StackLayout>

            <!-- Sample Issuing Buttons -->
            <Frame BackgroundColor="#E8F5E8" Padding="15" CornerRadius="8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="?? Quick Document Examples"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#388E3C"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="btnSampleInvoice"
                                Text="Sample Invoice"
                                Clicked="OnSampleInvoiceClicked"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="btnSampleReceipt"
                                Text="Sample Receipt"
                                Clicked="OnSampleReceiptClicked"
                                BackgroundColor="#FF5722"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="btnSampleCreditNote"
                                Text="Sample Credit Note"
                                Clicked="OnSampleCreditNoteClicked"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="btnSampleQuote"
                                Text="Sample Quote"
                                Clicked="OnSampleQuoteClicked"
                                BackgroundColor="#673AB7"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Additional Features -->
            <Frame BackgroundColor="#FFF3E0" Padding="15" CornerRadius="8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="?? Additional Operations"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#F57C00"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="btnValidateDocument"
                                Text="Validate Document"
                                Clicked="OnValidateDocumentClicked"
                                BackgroundColor="#3F51B5"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                        <Button x:Name="btnCancelDocument"
                                Text="Cancel Last Document"
                                Clicked="OnCancelDocumentClicked"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>