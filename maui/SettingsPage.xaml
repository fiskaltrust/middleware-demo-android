<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fiskaltrust.Middleware.Demo.SettingsPage"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Communication Protocol"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,0"/>

            <Border StrokeThickness="1"
                    Stroke="LightGray"
                    BackgroundColor="White"
                    Padding="15"
                    Margin="0,0,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="radioGrpc"
                                     GroupName="CommType"
                                     CheckedChanged="OnProtocolChanged"
                                     VerticalOptions="Start"/>
                        <VerticalStackLayout>
                            <Label Text="gRPC" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Fast binary protocol for high-performance communication"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </StackLayout>

                    <BoxView Color="LightGray" HeightRequest="1"/>

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="radioHttp"
                                     GroupName="CommType"
                                     CheckedChanged="OnProtocolChanged"
                                     VerticalOptions="Start"/>
                        <VerticalStackLayout>
                            <Label Text="HTTP/REST" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Standard HTTP REST API for maximum compatibility"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </StackLayout>

                    <BoxView Color="LightGray" HeightRequest="1"/>

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="radioIntent"
                                     GroupName="CommType"
                                     CheckedChanged="OnProtocolChanged"
                                     VerticalOptions="Start"/>
                        <VerticalStackLayout>
                            <Label Text="Intent-based" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Android Intent system for inter-app communication"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </StackLayout>

                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="#E3F2FD"
                    BackgroundColor="#E3F2FD"
                    Padding="15"
                    Margin="0,10,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="ℹ️ About Protocols" FontAttributes="Bold" FontSize="14"/>
                    <Label FontSize="12" LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="The selected protocol determines how this app communicates with the fiskaltrust.Middleware service.&#x0a;&#x0a;"/>
                                <Span Text="Make sure the corresponding launcher app (gRPC or HTTP) is installed and running on your device." FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Country Selection -->
            <Label Text="Country Configuration"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,30,0,0"/>

            <Border StrokeThickness="1"
                    Stroke="LightGray"
                    BackgroundColor="White"
                    Padding="15"
                    Margin="0,0,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="radioDE"
                                     GroupName="Country"
                                     CheckedChanged="OnCountryChanged"
                                     IsChecked="True"
                                     VerticalOptions="Start"/>
                        <VerticalStackLayout>
                            <Label Text="🇩🇪 Germany (DE)" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="German fiscal regulations and receipt cases"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </StackLayout>

                    <BoxView Color="LightGray" HeightRequest="1"/>

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="radioIT"
                                     GroupName="Country"
                                     CheckedChanged="OnCountryChanged"
                                     VerticalOptions="Start"/>
                        <VerticalStackLayout>
                            <Label Text="🇮🇹 Italy (IT)" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="Italian fiscal regulations and receipt cases"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </StackLayout>

                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="#E3F2FD"
                    BackgroundColor="#E3F2FD"
                    Padding="15"
                    Margin="0,0,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="ℹ️ About Country Settings" FontAttributes="Bold" FontSize="14"/>
                    <Label FontSize="12" LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="The selected country determines the fiscal receipt case codes used in sign operations.&#x0a;&#x0a;"/>
                                <Span Text="DE: Uses German fiscal regulations (0x4445_xxxx_xxxx_xxxx)&#x0a;"/>
                                <Span Text="IT: Uses Italian fiscal regulations (0x4954_xxxx_xxxx_xxxx)" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Logs Section -->
            <Label Text="Service Logs"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,30,0,0"/>

            <Border StrokeThickness="1"
                    Stroke="LightGray"
                    BackgroundColor="White"
                    Padding="15"
                    Margin="0,0,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Request logs from the middleware service (gRPC/HTTP only)"
                           FontSize="12"
                           TextColor="Gray"
                           LineBreakMode="WordWrap"/>
                    <Button x:Name="btnGetLogs"
                            Text="Request Logs"
                            Clicked="OnRequestLogsClicked"
                            HorizontalOptions="Fill"/>
                    <Label x:Name="txtLogs"
                           Text=""
                           FontSize="12"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
