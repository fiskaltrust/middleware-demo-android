<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fiskaltrust.Middleware.Demo.MainPage"
             Title="fiskaltrust.Middleware Demo">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <!-- Current Protocol Display -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,10">
                <Label Text="Protocol:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label x:Name="lblCurrentProtocol"
                       Text="gRPC"
                       TextColor="#2196F3"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Label Text="→ Change in Settings"
                       FontSize="12"
                       TextColor="Gray"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Retry Last Operation Button -->
            <Button x:Name="btnRetryLastOperation"
                    Text="🔄 Retry Last Operation"
                    Clicked="OnRetryLastOperationClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    IsVisible="False"
                    Margin="0,0,0,10" />

            <!-- Start/Stop Service Buttons -->
            <HorizontalStackLayout Spacing="10">
                <Button x:Name="btnStartService" Text="Start service" Clicked="OnStartServiceClicked" HorizontalOptions="FillAndExpand" />
                <Button x:Name="btnStopService" Text="Stop service" Clicked="OnStopServiceClicked" HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <Label x:Name="txtServiceStatus" Text="" HorizontalTextAlignment="Center" />

            <BoxView Color="LightGray" HeightRequest="1" Margin="10,15" />

            <!-- Echo Request -->
            <HorizontalStackLayout Spacing="10">
                <Button x:Name="btnSendEchoRequest"
                        Text="Send Echo Request"
                        Clicked="OnSendEchoRequestClicked"
                        HorizontalOptions="FillAndExpand" />
                <Button x:Name="btnRestartConfig"
                        Text="Restart &amp; Pull Config"
                        Clicked="OnRestartConfigClicked"
                        HorizontalOptions="FillAndExpand"
                        BackgroundColor="#FF6B6B" />
            </HorizontalStackLayout>
            <Label Text="Echo result:" FontAttributes="Bold" />
            <Label x:Name="txtResult" Text="" />

            <!-- Special Receipts -->
            <HorizontalStackLayout Spacing="10">
                <Button x:Name="btnSendStartReceipt" Text="Send start receipt" Clicked="OnSendStartReceiptClicked" HorizontalOptions="FillAndExpand" />
                <Button x:Name="btnSendZeroReceipt" Text="Send zero receipt" Clicked="OnSendZeroReceiptClicked" HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <Label Text="Special receipt result:" FontAttributes="Bold" />
            <Label x:Name="txtSpecialReceiptResult" Text="" />

            <!-- Sign Request -->
            <Button x:Name="btnSendSignRequest" Text="Send Sign Request" Clicked="OnSendSignRequestClicked" />
            <Label Text="Sign result:" FontAttributes="Bold" />
            <Label x:Name="txtSignResult" Text="" />


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
