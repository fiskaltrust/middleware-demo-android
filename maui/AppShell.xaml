<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="fiskaltrust.Middleware.Demo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:fiskaltrust.Middleware.Demo"
    Title="fiskaltrust.Middleware.Demo">

    <TabBar>
        <ShellContent
            Title="Demo"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="▶"
                    Size="20" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="⚙"
                    Size="20" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="About"
            ContentTemplate="{DataTemplate local:AboutPage}"
            Route="AboutPage">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="ℹ"
                    Size="20" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
